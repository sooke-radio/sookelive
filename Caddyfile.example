# Example Caddyfile for Sooke.live
# Copy this to Caddyfile on the server and customize for your domains.
#
# The deploy workflow names each app container sookelive-<branch>
# (sookelive-prd, sookelive-stg, ...), so each site block proxies to the
# container for its environment over the shared sookelive-network.

# Shared per-site config
(site-common) {
    # Enable compression
    encode gzip zstd

    # Security headers
    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }
}

# Production
sooke.live {
    import site-common
    reverse_proxy sookelive-prd:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# Staging
cms-stg.sooke.live {
    import site-common
    reverse_proxy sookelive-stg:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# Redirect www to non-www (optional)
www.sooke.live {
    redir https://sooke.live{uri} permanent
}
